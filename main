(function(){
  var railGeo = new THREE.BoxGeometry(0.12, 0.12, 1640);
  var railMat = new THREE.MeshBasicMaterial({ color: C.rec });
  [[-6,-3.5],[6,-3.5]].forEach(function(xy){
    var r = new THREE.Mesh(railGeo, railMat); r.position.set(xy[0], xy[1], -770); scene.add(r);
  });
  var dimGeo = new THREE.BoxGeometry(0.05, 0.05, 1640);
  var dimMat = new THREE.MeshBasicMaterial({ color: C.white, transparent: true, opacity: 0.3 });
  [[-6.9,-3.5],[6.9,-3.5]].forEach(function(xy){
    var r = new THREE.Mesh(dimGeo, dimMat); r.position.set(xy[0], xy[1], -770); scene.add(r);
  });
  var steps = isMobile ? 110 : 165;
  var ticks = new THREE.InstancedMesh(new THREE.BoxGeometry(0.8,0.07,0.07), new THREE.MeshBasicMaterial({ color:C.white, transparent:true, opacity:0.55 }), steps*2);
  var d = new THREE.Object3D();
  for (var i = 0; i < steps; i++){
    var z = 40 - i * (1620 / steps);
    d.position.set(-6,-3.5,z); d.updateMatrix(); ticks.setMatrixAt(i*2, d.matrix);
    d.position.set( 6,-3.5,z); d.updateMatrix(); ticks.setMatrixAt(i*2+1, d.matrix);
  }
  scene.add(ticks);
})();

/* ---------- keyframe diamonds ---------- */
(function(){
  var N = isMobile ? 70 : 120;
  var mesh = new THREE.InstancedMesh(new THREE.OctahedronGeometry(0.42), new THREE.MeshBasicMaterial({ color: 0xffffff }), N);
  var d = new THREE.Object3D(), tmp = new THREE.Color();
  var cols = [C.white, C.white, C.rec, C.cyan, C.vio];
  for (var i = 0; i < N; i++){
    var ang = Math.random()*Math.PI*2, rad = 9 + Math.random()*24;
    d.position.set(Math.cos(ang)*rad*1.5, Math.sin(ang)*rad*0.75, 50 - Math.random()*1600);
    d.rotation.set(Math.random()*3, Math.random()*3, Math.random()*3);
    var s = 0.5 + Math.random()*1.3;
    d.scale.set(s,s,s); d.updateMatrix();
    mesh.setMatrixAt(i, d.matrix);
    tmp.setHex(cols[Math.floor(Math.random()*cols.length)]);
    if (mesh.setColorAt) mesh.setColorAt(i, tmp);
  }
  if (mesh.instanceColor) mesh.instanceColor.needsUpdate = true;
  scene.add(mesh);
})();

/* ---------- ribbons ---------- */
function ribbon(zStart, zEnd, color, radX, radY){
  var pts = [];
  for (var i = 0; i <= 6; i++){
    var t = i/6, z = zStart + (zEnd - zStart)*t;
    pts.push(new THREE.Vector3(Math.sin(t*Math.PI*2.4 + zStart)*radX, Math.cos(t*Math.PI*1.7)*radY, z));
  }
  var geo = new THREE.TubeGeometry(new THREE.CatmullRomCurve3(pts), 140, 0.055, 6, false);
  scene.add(new THREE.Mesh(geo, new THREE.MeshBasicMaterial({ color:color, transparent:true, opacity:0.7, blending:THREE.AdditiveBlending, depthWrite:false })));
}
ribbon(20, -480, C.cyan, 10, 6);
ribbon(-380, -940, C.rec, 13, 7);
if (!isMobile) ribbon(-860, -1480, C.vio, 11, 8);

/* ---------- gates ---------- */
var gates = [];
function makeGate(z, color, scale){
  var g = new THREE.Group();
  g.add(new THREE.Mesh(new THREE.TorusGeometry(7,0.1,12,90), new THREE.MeshBasicMaterial({ color:color })));
  g.add(new THREE.Mesh(new THREE.TorusGeometry(7.6,0.03,8,90), new THREE.MeshBasicMaterial({ color:C.white, transparent:true, opacity:0.3 })));
  g.add(makeGlow(color, 30, 0.45));
  g.position.set(0, 1.5, z);
  g.userData.base = scale || 1;
  g.scale.set(g.userData.base, g.userData.base, 1);
  scene.add(g); gates.push(g);
}
makeGate(-350, C.cyan);
makeGate(-680, C.rec);
makeGate(-1030, C.vio);
makeGate(-1352, C.rec, 1.1);
makeGate(-1368, C.rec, 1.25);
