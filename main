    var ang = Math.random()*Math.PI*2, rad = 24 + Math.random()*60;
    s.position.set(Math.cos(ang)*rad*1.6, Math.sin(ang)*rad*0.7, 70 - Math.random()*1700);
    scene.add(s);
  }
})();

