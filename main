<script>
/* ====================================================================
   SEAS.SPACE v4 — 3D flythrough · chasing panels · feedback motion blur
==================================================================== */
(function(){
'use strict';
var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
var isMobile = Math.min(window.innerWidth, window.innerHeight) < 768;

/* ---------- boot ---------- */
var boot = document.getElementById('boot');
var logLines = document.querySelectorAll('#bootLog span');
var bootBar = document.getElementById('bootBar');
var bootPct = document.getElementById('bootPct');
var assembleStart = -1;
function bootDone(){
  if (boot) boot.classList.add('done');
  document.body.classList.add('loaded');
  assembleStart = performance.now();
}
if (reduced || !boot){ bootDone(); }
else {
  logLines.forEach(function(l, i){ setTimeout(function(){ l.classList.add('on'); }, 100 + i * 150); });
  var bp = 0;
  var biv = setInterval(function(){
    bp += Math.random() * 15 + 6;
    if (bp >= 100){ bp = 100; clearInterval(biv); setTimeout(bootDone, 240); }
    bootPct.textContent = Math.floor(bp) + '%';
    bootBar.style.transform = 'scaleX(' + (bp / 100) + ')';
  }, 100);
}

/* ---------- timecode / role / copy ---------- */
var tcEl = document.getElementById('tc');
var t0 = performance.now();
function pad(n){ return n < 10 ? '0' + n : '' + n; }
(function tick(){
  var el = (performance.now() - t0) / 1000;
  var f = Math.floor(el * 24);
  if (tcEl) tcEl.textContent = pad(Math.floor(el/3600)) + ':' + pad(Math.floor(el/60)%60) + ':' + pad(Math.floor(el)%60) + ':' + pad(f%24);
  requestAnimationFrame(tick);
})();

var roles = ['video editor','motion designer','colorist'];
var roleEl = document.getElementById('role');
var ri = 0;
if (roleEl && !reduced){
  roleEl.style.transition = 'opacity .2s';
  setInterval(function(){
    ri = (ri + 1) % roles.length;
    roleEl.style.opacity = '0';
    setTimeout(function(){ roleEl.textContent = roles[ri]; roleEl.style.opacity = '1'; }, 200);
  }, 2400);
}

var dc = document.getElementById('dcCopy');
var dcLab = document.getElementById('dcLab');
if (dc){
  dc.addEventListener('click', function(){
