  ring.position.set(0, 3.2, -62);
  ring.userData.base = 1;
  scene.add(ring); gates.push(ring);
  var glow = makeGlow(C.rec, 56, 0.3);
  glow.position.set(0, 3.5, -58);
  scene.add(glow);
})();

