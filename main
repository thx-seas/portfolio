var C = { rec: 0xFF3B30, cyan: 0x27E0FF, vio: 0x8C5BFF, white: 0xF4F3EF, gray: 0x878D96 };

function glowTexture(){
  var c = document.createElement('canvas');
  c.width = c.height = 128;
  var g = c.getContext('2d');
  var r = g.createRadialGradient(64, 64, 0, 64, 64, 64);
  r.addColorStop(0, 'rgba(255,255,255,1)');
  r.addColorStop(0.28, 'rgba(255,255,255,0.55)');
  r.addColorStop(1, 'rgba(255,255,255,0)');
  g.fillStyle = r; g.fillRect(0, 0, 128, 128);
  return new THREE.CanvasTexture(c);
}
var GLOW = glowTexture();
function makeGlow(color, scale, opacity){
  var s = new THREE.Sprite(new THREE.SpriteMaterial({ map: GLOW, color: color, transparent: true, opacity: opacity, blending: THREE.AdditiveBlending, depthWrite: false }));
  s.scale.set(scale, scale, 1);
  return s;
}
function makeLabel(txt, colorCss, scaleW, dot){
  var c = document.createElement('canvas');
  c.width = 512; c.height = 96;
  var g = c.getContext('2d');
  g.font = '600 50px "IBM Plex Mono", monospace';
  g.textBaseline = 'middle';
  var x = 10;
  if (dot !== false){ g.fillStyle = '#FF3B30'; g.fillText('●', x, 50); x += 52; }
  g.fillStyle = colorCss;
  g.fillText(txt, x, 50);
  var tex = new THREE.CanvasTexture(c);
  var s = new THREE.Sprite(new THREE.SpriteMaterial({ map: tex, transparent: true, opacity: 0.95, depthWrite: false }));
  s.scale.set(scaleW, scaleW * 96 / 512, 1);
  return s;
}

/* ---------- starfield ---------- */
(function(){
  var N = isMobile ? 1100 : 2200;
  var pos = new Float32Array(N * 3), col = new Float32Array(N * 3);
  var pal = [[0.95,0.93,0.9],[0.95,0.93,0.9],[0.95,0.93,0.9],[1,0.28,0.22],[0.18,0.86,1],[0.6,0.4,1]];
  for (var i = 0; i < N; i++){
    pos[i*3] = (Math.random()-0.5)*160;
    pos[i*3+1] = (Math.random()-0.5)*90;
    pos[i*3+2] = 60 - Math.random()*1640;
    var c = pal[Math.floor(Math.random()*pal.length)], v = 0.5 + Math.random()*0.5;
    col[i*3]=c[0]*v; col[i*3+1]=c[1]*v; col[i*3+2]=c[2]*v;
  }
  var g = new THREE.BufferGeometry();
  g.setAttribute('position', new THREE.BufferAttribute(pos,3));
  g.setAttribute('color', new THREE.BufferAttribute(col,3));
  scene.add(new THREE.Points(g, new THREE.PointsMaterial({ size:0.8, vertexColors:true, transparent:true, opacity:0.95, blending:THREE.AdditiveBlending, depthWrite:false })));
})();

