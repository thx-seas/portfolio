/* ---------- giant analog clock — full motion port of the original ---------- */
var updateClock = function(){};
(function(){
  var g = new THREE.Group();
  var R = 64;
  g.position.set(0, 16, -272);
  scene.add(g);

  /* dials */
  g.add(new THREE.Mesh(new THREE.TorusGeometry(R, 0.10, 8, 170), new THREE.MeshBasicMaterial({ color: C.white, transparent: true, opacity: 0.2 })));
  g.add(new THREE.Mesh(new THREE.TorusGeometry(R*0.93, 0.05, 8, 150), new THREE.MeshBasicMaterial({ color: C.white, transparent: true, opacity: 0.08 })));

  /* 60 ticks, every 5th long */
  var ticks = new THREE.InstancedMesh(new THREE.BoxGeometry(1, 0.16, 0.16), new THREE.MeshBasicMaterial({ color: C.white, transparent: true, opacity: 0.35 }), 60);
  var td = new THREE.Object3D();
  for (var i = 0; i < 60; i++){
    var a0 = (i / 60) * Math.PI * 2;
    var major = i % 5 === 0;
    td.position.set(Math.cos(a0) * R * 1.045, Math.sin(a0) * R * 1.045, 0);
    td.rotation.set(0, 0, a0);
    td.scale.set(major ? 4.4 : 1.9, major ? 1.5 : 1, 1);
    td.updateMatrix();
    ticks.setMatrixAt(i, td.matrix);
  }
  g.add(ticks);

  /* numerals */
  [['12', 0, 1], ['3', 1, 0], ['6', 0, -1], ['9', -1, 0]].forEach(function(n){
    var s = makeLabel(n[0], '#878D96', 9, false);
    s.position.set(n[1] * R * 1.16, n[2] * R * 1.16, 0);
    g.add(s);
  });

  /* rotating decorative arcs with glowing end dots */
  var arcs = [];
  [[0.65, 0.18, 0.55 * Math.PI * 2, C.rec,  0.5,  0.10],
   [0.52, -0.13, 0.35 * Math.PI * 2, C.cyan, 0.38, 0.08],
   [0.74, 0.07, 0.65 * Math.PI * 2, C.white, 0.14, 0.06]].forEach(function(A, i){
    var r = R * A[0];
    var m = new THREE.Mesh(new THREE.TorusGeometry(r, A[5], 6, 90, A[2]), new THREE.MeshBasicMaterial({ color: A[3], transparent: true, opacity: A[4] }));
    m.rotation.z = i * 1.5;
    var dot = makeGlow(A[3], 4.5, 0.6);
    dot.position.set(Math.cos(A[2]) * r, Math.sin(A[2]) * r, 0);
    m.add(dot);
    g.add(m);
    arcs.push({ m: m, speed: A[1], baseOp: A[4], ph: i * 1.5 });
  });

  /* inner segmented rings (rotating) */
  var segRings = [];
  [[0.18, 8, 0.18, C.rec, 0.10], [0.30, 12, -0.11, C.cyan, 0.07]].forEach(function(rg){
    var grp = new THREE.Group();
    var r = R * rg[0], segs = rg[1], span = (Math.PI * 2 / segs) * 0.4;
    for (var s = 0; s < segs; s++){
      var seg = new THREE.Mesh(new THREE.TorusGeometry(r, rg[4] * 9, 5, 24, span), new THREE.MeshBasicMaterial({ color: rg[3], transparent: true, opacity: 0.24 }));
      seg.rotation.z = (s / segs) * Math.PI * 2;
      grp.add(seg);
    }
    g.add(grp);
    segRings.push({ grp: grp, speed: rg[2] });
  });

  /* orbiting orbs with comet trails */
  var ORBS = [
    { rf: 0.70, speed: 0.22,  size: 3.0, col: C.rec,  ph: 0 },
    { rf: 0.62, speed: -0.18, size: 2.5, col: C.cyan, ph: 3.3 },
    { rf: 0.46, speed: 0.42,  size: 2.2, col: C.rec,  ph: 0 },
    { rf: 0.46, speed: 0.42,  size: 2.2, col: C.cyan, ph: Math.PI * 2 / 3 },
    { rf: 0.46, speed: 0.42,  size: 2.2, col: C.vio,  ph: Math.PI * 4 / 3 },
    { rf: 0.26, speed: -0.65, size: 1.7, col: C.cyan, ph: 0 },
    { rf: 0.26, speed: -0.65, size: 1.7, col: C.rec,  ph: Math.PI }
  ];
  var TRAIL = 16;
  ORBS.forEach(function(o){
    var r = R * o.rf;
    var x0 = Math.cos(o.ph) * r, y0 = Math.sin(o.ph) * r;
    var pos = new Float32Array(TRAIL * 3);
    var col = new Float32Array(TRAIL * 3);
    var cc = new THREE.Color(o.col);
    for (var i = 0; i < TRAIL; i++){
      pos[i*3] = x0; pos[i*3+1] = y0; pos[i*3+2] = 0;
      var f = (i / (TRAIL - 1)); f = f * f;
      col[i*3] = cc.r * f; col[i*3+1] = cc.g * f; col[i*3+2] = cc.b * f;
    }
    var geo = new THREE.BufferGeometry();
    geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
    geo.setAttribute('color', new THREE.BufferAttribute(col, 3));
    o.line = new THREE.Line(geo, new THREE.LineBasicMaterial({ vertexColors: true, transparent: true, opacity: 0.85, blending: THREE.AdditiveBlending, depthWrite: false }));
    g.add(o.line);
    o.head = makeGlow(o.col, o.size * 2.6, 0.75);
    o.core = makeGlow(0xffffff, o.size * 0.9, 0.9);
    o.head.position.set(x0, y0, 0); o.core.position.set(x0, y0, 0);
    g.add(o.head); g.add(o.core);
  });

  /* drifting particles that flee from the cursor */
  var PN = 200;
  var px = new Float32Array(PN), py = new Float32Array(PN);
  var pox = new Float32Array(PN), poy = new Float32Array(PN);
  var pvx = new Float32Array(PN), pvy = new Float32Array(PN);
  var pph = new Float32Array(PN), psp = new Float32Array(PN);
  var pdA = new Float32Array(PN), pdV = new Float32Array(PN), pmr = new Float32Array(PN);
  var ppos = new Float32Array(PN * 3), pcol = new Float32Array(PN * 3);
  var ppal = [[1, 0.28, 0.22], [0.18, 0.86, 1], [0.93, 0.91, 0.96]];
  for (var pi = 0; pi < PN; pi++){
    var inner = pi < 110;
    var rr = inner ? R * (0.08 + Math.pow(Math.random(), 1.3) * 0.55) : R * (0.68 + Math.random() * 0.2);
    var aa = Math.random() * Math.PI * 2;
    pox[pi] = Math.cos(aa) * rr; poy[pi] = Math.sin(aa) * rr;
    px[pi] = pox[pi]; py[pi] = poy[pi];
    pph[pi] = Math.random() * Math.PI * 2;
    psp[pi] = 0.05 + Math.random() * 0.05;
    pdA[pi] = Math.random() * Math.PI * 2;
    pdV[pi] = (Math.random() - 0.5) * 0.012;
    pmr[pi] = inner ? R * 0.62 : R * 0.92;
    ppos[pi*3] = px[pi]; ppos[pi*3+1] = py[pi]; ppos[pi*3+2] = (Math.random() - 0.5) * 3;
    var pc = ppal[Math.floor(Math.random() * ppal.length)], pv = 0.4 + Math.random() * 0.5;
    pcol[pi*3] = pc[0]*pv; pcol[pi*3+1] = pc[1]*pv; pcol[pi*3+2] = pc[2]*pv;
  }
  var pgeo = new THREE.BufferGeometry();
  var pAttr = new THREE.BufferAttribute(ppos, 3);
  pgeo.setAttribute('position', pAttr);
  pgeo.setAttribute('color', new THREE.BufferAttribute(pcol, 3));
  g.add(new THREE.Points(pgeo, new THREE.PointsMaterial({ size: 0.85, vertexColors: true, transparent: true, opacity: 0.9, blending: THREE.AdditiveBlending, depthWrite: false })));

  /* hands: red = auto sweep, cyan = follows the cursor with lag */
  function makeHand(len, w, color){
    var h = new THREE.Group();
    var tail = R * 0.17;
    var bar = new THREE.Mesh(new THREE.BoxGeometry(w, len + tail, w), new THREE.MeshBasicMaterial({ color: color }));
    bar.position.y = (len - tail) / 2;
    h.add(bar);
    var tip = new THREE.Mesh(new THREE.OctahedronGeometry(1.5), new THREE.MeshBasicMaterial({ color: color }));
    tip.position.y = len;
    h.add(tip);
    var gl = makeGlow(color, 8, 0.45);
    gl.position.y = len;
    h.add(gl);
    g.add(h);
    return h;
  }
  var handAuto = makeHand(R * 0.60, 0.5, C.rec);
  var handMouse = makeHand(R * 0.74, 0.28, C.cyan);
  var autoAng = 0, mAng = 0, mAngT = 0;

  /* center pivot + pulsing core glow */
  g.add(new THREE.Mesh(new THREE.TorusGeometry(1.7, 0.16, 8, 44), new THREE.MeshBasicMaterial({ color: C.white, transparent: true, opacity: 0.65 })));
  var coreGlow = makeGlow(C.rec, 14, 0.22);
  g.add(coreGlow);

  /* expanding pulse rings */
  var pulses = [];
  for (var qi = 0; qi < 3; qi++){
    var pm = new THREE.Mesh(new THREE.RingGeometry(0.96, 1, 64), new THREE.MeshBasicMaterial({ color: C.rec, transparent: true, opacity: 0, side: THREE.DoubleSide, blending: THREE.AdditiveBlending, depthWrite: false }));
    pm.visible = false;
    g.add(pm);
    pulses.push({ m: pm, life: 0 });
  }
  var nextPulse = 1.5;
  function eio3(t){ return t < 0.5 ? 4*t*t*t : (t-1)*(2*t-2)*(2*t-2)+1; }

  updateClock = function(dt, now){
    var t = now * 0.001;

    /* hands */
    autoAng -= dt * 0.10;
    handAuto.rotation.z = autoAng;
    var targ = Math.atan2(-mxs, -mys);
    var diff = targ - mAngT;
    while (diff > Math.PI) diff -= Math.PI * 2;
    while (diff < -Math.PI) diff += Math.PI * 2;
    mAngT += diff;
    mAng += (mAngT - mAng) * Math.min(1, dt * 2.5);
    handMouse.rotation.z = mAng;

    /* arcs */
    for (var i = 0; i < arcs.length; i++){
      var A = arcs[i];
      A.m.rotation.z -= A.speed * dt;
      A.m.material.opacity = A.baseOp * (0.88 + Math.sin(t * 0.5 + A.ph) * 0.12);
      var sc = 1 + Math.sin(t * 0.4 + A.ph) * 0.02;
      A.m.scale.set(sc, sc, 1);
    }
    for (var r2 = 0; r2 < segRings.length; r2++) segRings[r2].grp.rotation.z -= segRings[r2].speed * dt;

    /* orbs + trails */
    for (var o2 = 0; o2 < ORBS.length; o2++){
      var O = ORBS[o2];
      var ang = O.ph + t * O.speed;
      var ox2 = Math.cos(ang) * R * O.rf, oy2 = Math.sin(ang) * R * O.rf;
      var arr = O.line.geometry.attributes.position.array;
      arr.copyWithin(0, 3);
      arr[(TRAIL-1)*3] = ox2; arr[(TRAIL-1)*3+1] = oy2; arr[(TRAIL-1)*3+2] = 0;
      O.line.geometry.attributes.position.needsUpdate = true;
      O.head.position.set(ox2, oy2, 0);
      O.core.position.set(ox2, oy2, 0);
    }

    /* particles: drift + spring + flee from cursor */
    var sx = mxs * R * 0.9, sy = -mys * R * 0.55;
    var REP = R * 0.14;
    for (var p2 = 0; p2 < PN; p2++){
      pph[p2] += psp[p2] * dt * 60 * 0.016;
      pdA[p2] += pdV[p2] * dt * 60 * 0.016;
      pox[p2] += Math.cos(pdA[p2]) * 0.022 * dt * 60;
      poy[p2] += Math.sin(pdA[p2]) * 0.022 * dt * 60;
      var d0 = Math.sqrt(pox[p2]*pox[p2] + poy[p2]*poy[p2]) || 0.001;
      if (d0 > pmr[p2]){ pox[p2] -= pox[p2]/d0 * 0.12; poy[p2] -= poy[p2]/d0 * 0.12; }
      pvx[p2] += (pox[p2] - px[p2]) * 0.016 + Math.sin(pph[p2] * 1.2) * 0.012;
      pvy[p2] += (poy[p2] - py[p2]) * 0.016 + Math.cos(pph[p2] * 0.9) * 0.012;
      var mdx = px[p2] - sx, mdy = py[p2] - sy;
      var md = Math.sqrt(mdx*mdx + mdy*mdy);
      if (md < REP && md > 0.05){
        var f = (REP - md) / REP * 0.45;
        pvx[p2] += mdx / md * R * 0.010 * f;
        pvy[p2] += mdy / md * R * 0.010 * f;
      }
      pvx[p2] *= 0.84; pvy[p2] *= 0.84;
      px[p2] += pvx[p2]; py[p2] += pvy[p2];
      ppos[p2*3] = px[p2]; ppos[p2*3+1] = py[p2];
    }
    pAttr.needsUpdate = true;

    /* center pulse + rings */
    var cg = 1 + Math.sin(t * 1.9) * 0.07;
    coreGlow.scale.set(14 * cg, 14 * cg, 1);
    if (t >= nextPulse){
      for (var q2 = 0; q2 < pulses.length; q2++){
        if (pulses[q2].life <= 0){
          pulses[q2].life = 1;
          pulses[q2].m.material.color.setHex(Math.random() < 0.6 ? C.rec : C.cyan);
          pulses[q2].m.visible = true;
          break;
        }
      }
      nextPulse = t + 1.8 + Math.random() * 0.5;
    }
    for (var q3 = 0; q3 < pulses.length; q3++){
      var P = pulses[q3];
      if (P.life > 0){
        P.life -= dt / 2.6;
        var prog = 1 - Math.max(0, P.life);
        var rr2 = Math.max(0.001, eio3(prog) * R * 0.86);
        P.m.scale.set(rr2, rr2, 1);
        P.m.material.opacity = (1 - prog) * (1 - prog) * 0.25;
        if (P.life <= 0) P.m.visible = false;
      }
    }
  };
})();

/* ---------- voxel SEAS ---------- */
var vox = null, voxStarts = [], voxTargets = [], voxRots = [];
(function(){
  var F = {
    S:['01111','10000','10000','01110','00001','00001','11110'],
    E:['11111','10000','10000','11110','10000','10000','11111'],
    A:['01110','10001','10001','11111','10001','10001','10001']
  };
  var word = ['S','E','A','S'];
  var cell = 0.98, lw = 5*cell, gap = 2*cell;
  var x0 = -(word.length*lw + (word.length-1)*gap)/2 + cell/2;
  var cy = 3.5, cz = -46;
  word.forEach(function(ch, li){
    var grid = F[ch];
    for (var row = 0; row < 7; row++) for (var col = 0; col < 5; col++){
      if (grid[row][col] === '1'){
        voxTargets.push(new THREE.Vector3(x0 + li*(lw+gap) + col*cell, cy + (3-row)*cell, cz));
        var dir = new THREE.Vector3(Math.random()-0.5, Math.random()-0.5, Math.random()-0.5).normalize();
        voxStarts.push(dir.multiplyScalar(28 + Math.random()*55).add(new THREE.Vector3(0, cy, cz + 20)));
        voxRots.push(new THREE.Euler(Math.random()*6, Math.random()*6, Math.random()*6));
      }
    }
  });
  vox = new THREE.InstancedMesh(new THREE.BoxGeometry(0.8,0.8,0.8), new THREE.MeshBasicMaterial({ color:0xffffff }), voxTargets.length);
  var tmp = new THREE.Color();
  for (var i = 0; i < voxTargets.length; i++){
    var r = Math.random();
    tmp.setHex(r < 0.9 ? C.white : C.rec);
    if (vox.setColorAt) vox.setColorAt(i, tmp);
  }
  if (vox.instanceColor) vox.instanceColor.needsUpdate = true;
  scene.add(vox);
})();
var voxDummy = new THREE.Object3D(), voxSettled = false;
function easeOutCubic(t){ return 1 - Math.pow(1-t, 3); }
function updateVox(now){
  var t = assembleStart < 0 ? 0 : Math.min(1, (now - assembleStart)/2300);
  var e = easeOutCubic(t);
  for (var i = 0; i < voxTargets.length; i++){
    voxDummy.position.lerpVectors(voxStarts[i], voxTargets[i], e);
    voxDummy.rotation.set(voxRots[i].x*(1-e), voxRots[i].y*(1-e), voxRots[i].z*(1-e));
    voxDummy.updateMatrix();
    vox.setMatrixAt(i, voxDummy.matrix);
  }
  vox.instanceMatrix.needsUpdate = true;
  return t >= 1;
}

/* ---------- clip blocks / bin sculpture / end glow ---------- */
var clips = [];
function makeClip(x, y, z, color){
  var g = new THREE.Group();
  var box = new THREE.Mesh(new THREE.BoxGeometry(7,1.5,3), new THREE.MeshBasicMaterial({ color:color, transparent:true, opacity:0.06 }));
  g.add(box);
  g.add(new THREE.LineSegments(new THREE.EdgesGeometry(box.geometry), new THREE.LineBasicMaterial({ color:color })));
  g.position.set(x,y,z);
  g.userData = { spin: 0.0015 + Math.random()*0.002, phase: Math.random()*6, baseY: y };
  scene.add(g); clips.push(g);
}
makeClip(-11, 4.5, -640, C.rec);
makeClip( 11, 1.5, -668, C.cyan);
makeClip(-11,-1.0, -696, C.white);
makeClip( 11, 6.0, -724, C.vio);

var ico = new THREE.Mesh(new THREE.IcosahedronGeometry(6,1), new THREE.MeshBasicMaterial({ color:C.white, wireframe:true, transparent:true, opacity:0.22 }));
ico.position.set(0, 2, -1005); scene.add(ico);
var oct = new THREE.Mesh(new THREE.OctahedronGeometry(2.4), new THREE.MeshBasicMaterial({ color:C.vio, wireframe:true, transparent:true, opacity:0.55 }));
oct.position.copy(ico.position); scene.add(oct);

var endGlow = makeGlow(C.rec, 80, 0.32);
endGlow.position.set(0, 1.5, -1430); scene.add(endGlow);

/* ---------- shockwaves ---------- */
var waves = [];
for (var wi = 0; wi < 4; wi++){
  var wm = new THREE.Mesh(new THREE.RingGeometry(0.62,0.75,48), new THREE.MeshBasicMaterial({ color:C.cyan, transparent:true, opacity:0, side:THREE.DoubleSide, blending:THREE.AdditiveBlending, depthWrite:false }));
  wm.visible = false; scene.add(wm);
  waves.push({ mesh: wm, life: 0 });
}
var fwd = new THREE.Vector3();
window.addEventListener('pointerdown', function(e){
  if (e.target.closest && e.target.closest('a,button,.pbox,.p3d')) return;
  for (var i = 0; i < waves.length; i++){
    if (waves[i].life <= 0){
      var w = waves[i];
      camera.getWorldDirection(fwd);
      w.mesh.position.copy(camera.position).addScaledVector(fwd, 20);
      w.mesh.lookAt(camera.position);
      w.mesh.scale.set(1,1,1);
      w.mesh.material.color.setHex(Math.random() < 0.5 ? C.cyan : C.rec);
      w.mesh.visible = true; w.life = 1;
      break;
    }
  }
});

/* ---------- panel fades (fixed overlays) ---------- */
function smooth01(x){ return x <= 0 ? 0 : x >= 1 ? 1 : x*x*(3 - 2*x); }
function updatePanels(p){
  for (var i = 0; i < PANELS.length; i++){
    var pn = PANELS[i];
    var oIn = pn.a <= -0.5 ? 1 : smooth01((p - pn.a) / 0.05);
    var oOut = pn.b > 5 ? 0 : smooth01((p - pn.b) / 0.06);
    var o = Math.max(0, Math.min(oIn, 1 - oOut));
    pn.el.style.opacity = o.toFixed(3);
    pn.el.classList.toggle('live', o > 0.4);
  }
}

/* ---------- scroll + mouse + dots ---------- */
var targetP = 0, p = 0;
function readScroll(){
  var max = spacer.offsetHeight - window.innerHeight;
  targetP = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
}
window.addEventListener('scroll', readScroll, { passive: true });
readScroll();

var mx = 0, my = 0, mxs = 0, mys = 0;
var xyEl = document.getElementById('xy');
window.addEventListener('mousemove', function(e){
  mx = (e.clientX / window.innerWidth)*2 - 1;
  my = (e.clientY / window.innerHeight)*2 - 1;
  if (xyEl) xyEl.textContent = 'x:' + mx.toFixed(2) + ' · y:' + (-my).toFixed(2);
}, { passive: true });

dots.forEach(function(d){
  d.addEventListener('click', function(){
    var max = spacer.offsetHeight - window.innerHeight;
    window.scrollTo({ top: parseFloat(d.getAttribute('data-p')) * max, behavior: 'smooth' });
  });
});

window.addEventListener('resize', function(){
  camera.aspect = window.innerWidth / window.innerHeight;
  camera.updateProjectionMatrix();
  renderer.setSize(window.innerWidth, window.innerHeight);
  renderer.clear();
});

/* ---------- main loop ---------- */
var lastT = performance.now();
var stationBounds = [0.13, 0.37, 0.595, 0.83];
function loop(now){
  var dt = Math.min(0.045, (now - lastT)/1000);
  lastT = now;

  p += (targetP - p) * 0.075;
  mxs += (mx - mxs) * 0.06;
  mys += (my - mys) * 0.06;
  var speed = Math.abs(targetP - p);

  updateClock(dt, now);
  if (!voxSettled) voxSettled = updateVox(now);
  else { vox.position.y = Math.sin(now*0.0008)*0.3; vox.rotation.y = Math.sin(now*0.0003)*0.04; }

  for (var i = 0; i < gates.length; i++){
    var g = gates[i];
    g.rotation.z += (i % 2 ? -1 : 1) * 0.0016;
    var gs = g.userData.base * (1 + Math.sin(now*0.002 + i*1.7)*0.035);
    g.scale.set(gs, gs, 1);
  }
  for (var j = 0; j < clips.length; j++){
    var c = clips[j];
    c.rotation.y += c.userData.spin;
    c.position.y = c.userData.baseY + Math.sin(now*0.001 + c.userData.phase)*0.5;
  }
  ico.rotation.y += 0.0022; ico.rotation.x += 0.0009;
  oct.rotation.y -= 0.004; oct.rotation.z += 0.002;

  for (var k = 0; k < waves.length; k++){
    var w = waves[k];
    if (w.life > 0){
      w.life -= dt * 1.5;
      var s = 1 + (1 - w.life) * 36;
      w.mesh.scale.set(s, s, 1);
      w.mesh.material.opacity = Math.max(0, w.life) * 0.8;
      if (w.life <= 0) w.mesh.visible = false;
    }
  }

  var camZ = 20 - p * 1480;
  var camX = Math.sin(p * Math.PI * 4) * 3.0 + mxs * 1.8;
  var camY = 1.5 + Math.sin(p * Math.PI * 2.3) * 1.2 - mys * 1.2;
  camera.position.set(camX, camY, camZ);
  camera.lookAt(camX*0.5 + mxs*4.5, camY*0.6 - mys*2.6, camZ - 28);
  camera.rotation.z = mxs*0.055 + Math.max(-0.12, Math.min(0.12, (targetP - p)*1.4));

  var fovT = 72 + Math.min(16, speed * 130);
  if (Math.abs(camera.fov - fovT) > 0.05){
    camera.fov += (fovT - camera.fov) * 0.1;
    camera.updateProjectionMatrix();
  }

  updatePanels(p);

  if (hint) hint.classList.toggle('off', p > 0.025);
  var active = 0;
  for (var s2 = 0; s2 < stationBounds.length; s2++) if (p > stationBounds[s2]) active = s2 + 1;
  for (var d2 = 0; d2 < dots.length; d2++) dots[d2].classList.toggle('on', d2 === active);

  /* motion blur feedback: faster flight = longer trails */
  fadeMat.opacity = Math.max(0.07, Math.min(0.45, 0.45 - speed * 5.5));
  renderer.render(fadeScene, fadeCam);
  renderer.clearDepth();
  renderer.render(scene, camera);

  requestAnimationFrame(loop);
}
requestAnimationFrame(loop);
})();
</script>
</body>
</html>
